# ─────────────────────────────────────────────────────────────────────────────
# SARI-AGENT — Environment Variables
# Copy this file to .env.local and fill in every required value.
# NEVER commit .env.local — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string.
# Create a cluster at https://cloud.mongodb.com, then:
#   Database Access  → add a user with readWrite on your DB
#   Network Access   → allow 0.0.0.0/0 (Vercel uses dynamic IPs)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret used to sign and verify JWT session tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# MUST be changed from any default before deploying to production.
JWT_SECRET=replace-with-a-long-random-secret

# ── OpenAI ────────────────────────────────────────────────────────────────────
# API key from https://platform.openai.com/api-keys
# Used for: AI assistant intent parsing + Whisper voice transcription.
OPENAI_API_KEY=sk-proj-...

# Optional: override the assistant parser model (default: gpt-5-mini).
# OPENAI_PARSER_MODEL=gpt-4o-mini

# ── SMS / Twilio ───────────────────────────────────────────────────────────────
# Controls phone-number verification behaviour:
#   development  → verification codes are printed to the server console only
#   sandbox      → uses Twilio test credentials (no real SMS, no charge)
#   production   → sends real SMS (requires TWILIO_* credentials below)
SMS_MODE=development

# Required only when SMS_MODE=production or SMS_MODE=sandbox.
# https://console.twilio.com → Account Info
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Dev only (remove in production) ───────────────────────────────────────────
# Comma-separated hostnames allowed for HMR when testing from another device.
# No protocol, no port. Example: ALLOWED_DEV_ORIGINS=10.0.0.3
# ALLOWED_DEV_ORIGINS=
