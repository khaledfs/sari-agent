# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.idea/
settings.local.json

# local HTTPS dev setup (mkcert)
mkcert.exe
*.key.pem
*+*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example, ignore everything else
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# archives
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.lzma
*.tar.lz
*.tar.zst
*.tar.zstd
*.tar.zstd

# logs
*.log

# local scratch files
tmp_flours.html

# ML export + trained artifacts (regenerate locally)
artifacts/recommendation-data/*.jsonl
artifacts/recommendation-logreg/

# ML requirements
requirements-ml.txt